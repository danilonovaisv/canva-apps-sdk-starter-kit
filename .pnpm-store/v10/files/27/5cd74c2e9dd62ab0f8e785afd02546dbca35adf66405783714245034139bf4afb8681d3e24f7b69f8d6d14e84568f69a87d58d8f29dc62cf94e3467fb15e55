  "sources": ["../../../../src/express/index.ts", "../../../../src/constants.ts", "../../../../src/core/user.ts", "../../../../src/errors.ts", "../../../../src/core/utils.ts", "../../../../src/express/user/extractors.ts", "../../../../src/express/user/middleware.ts"],
  "sourcesContent": ["// Express middleware exports\nexport { tokenExtractors, user } from \"./user/index.js\";\n\n// Express-specific types\nexport type { TokenExtractor, UserAuthOptions } from \"./user/index.js\";\n", "import debug from \"debug\";\n\n/**\n * Shared debug logger for the app middleware package.\n * Enable with DEBUG=canva:app:middleware\n */\nexport const debugLogger = debug(\"canva:app:middleware\");\n\n/** Default Canva API base URL */\nexport const CANVA_BASE_URL = \"https://api.canva.com\";\n\n/** Default JWKS cache duration in minutes */\nexport const DEFAULT_CACHE_MAX_AGE_MINUTES = 60;\n\n/** Default JWKS fetch timeout in milliseconds */\nexport const DEFAULT_TIMEOUT_MS = 30_000;\n", "import jwt from \"jsonwebtoken\";\nimport { JwksClient, SigningKeyNotFoundError } from \"jwks-rsa\";\nimport {\n  CANVA_BASE_URL,\n  debugLogger,\n  DEFAULT_CACHE_MAX_AGE_MINUTES,\n  DEFAULT_TIMEOUT_MS,\n} from \"../constants.js\";\nimport { TokenExpiredError, TokenInvalidError } from \"../errors.js\";\nimport type {\n  UserTokenPayload,\n  UserTokenVerifier,\n  UserTokenVerifierOptions,\n} from \"./types.js\";\nimport { createJwksUrl } from \"./utils.js\";\n\ntype CanvaJwt = Omit<jwt.Jwt, \"payload\"> & {\n  payload: {\n    aud?: string;\n    userId?: string;\n    brandId?: string;\n    exp?: number;\n  };\n};\n\n/**\n * @public\n * Initializes a user token verifier with the given configuration.\n *\n * The verifier caches JWKS public keys according to the configured cache settings.\n * Create one verifier instance and reuse it for all verification requests.\n *\n * @param options - Configuration options for the verifier\n * @returns A configured verifier instance\n *\n * @example\n * ```typescript\n * import { initUserTokenVerifier } from '@canva/app-middleware';\n *\n * // Initialize once at app startup\n * const verifier = initUserTokenVerifier({\n *   appId: process.env.CANVA_APP_ID,\n * });\n *\n * // Verify tokens per request\n * const payload = await verifier.verify(token);\n * console.log(payload.userId, payload.brandId);\n * ```\n *\n * @example\n * With custom options:\n * ```typescript\n * const verifier = initUserTokenVerifier({\n *   appId: process.env.CANVA_APP_ID,\n *   cacheMaxAgeMinutes: 30,\n *   timeoutMs: 10000,\n * });\n * ```\n */\nexport function initUserTokenVerifier(\n  options: UserTokenVerifierOptions,\n): UserTokenVerifier {\n  const {\n    appId,\n    cacheMaxAgeMinutes = DEFAULT_CACHE_MAX_AGE_MINUTES,\n    timeoutMs = DEFAULT_TIMEOUT_MS,\n    baseUrl = CANVA_BASE_URL,\n  } = options;\n\n  // Create the JWKS client once during initialization\n  const jwksClient = new JwksClient({\n    cache: true,\n    cacheMaxAge: cacheMaxAgeMinutes * 60 * 1000,\n    timeout: timeoutMs,\n    rateLimit: true,\n    jwksUri: createJwksUrl(baseUrl, appId),\n  });\n\n  return {\n    async verify(token: string): Promise<UserTokenPayload> {\n      debugLogger(\"Verifying user token for appId: %s\", appId);\n\n      // Decode the token to get the key ID\n      const unverifiedDecodedToken = jwt.decode(token, { complete: true });\n\n      if (unverifiedDecodedToken?.header?.kid == null) {\n        debugLogger(\"Expected token to contain 'kid' claim header\");\n        throw new TokenInvalidError(\n          \"Token is missing required 'kid' header\",\n          \"Missing kid header\",\n        );\n      }\n\n      try {\n        const key = await jwksClient.getSigningKey(\n          unverifiedDecodedToken.header.kid,\n        );\n        const publicKey = key.getPublicKey();\n\n        const verifiedToken = jwt.verify(token, publicKey, {\n          audience: appId,\n          complete: true,\n          algorithms: [\"RS256\"],\n          issuer: baseUrl,\n        }) as CanvaJwt;\n\n        const { payload } = verifiedToken;\n        debugLogger(\"Payload: %O\", payload);\n\n        if (\n          payload.userId == null ||\n          payload.brandId == null ||\n          payload.aud == null\n        ) {\n          debugLogger(\"Failed to decode JWT: missing fields from payload\");\n          throw new TokenInvalidError(\n            \"Token is missing required claims\",\n            \"Missing userId, brandId, or aud claims\",\n          );\n        }\n\n        return {\n          appId: payload.aud,\n          userId: payload.userId,\n          brandId: payload.brandId,\n        };\n      } catch (e) {\n        if (e instanceof SigningKeyNotFoundError) {\n          throw new TokenInvalidError(\n            \"Public key not found. Ensure you have the correct App ID set\",\n            \"Signing key not found\",\n          );\n        }\n\n        if (e instanceof jwt.TokenExpiredError) {\n          throw new TokenExpiredError(\"Token has expired\", e.expiredAt);\n        }\n\n        if (e instanceof jwt.JsonWebTokenError) {\n          throw new TokenInvalidError(\"Token is invalid\", e.message);\n        }\n\n        throw e;\n      }\n    },\n  };\n}\n", "/**\n * @public\n * An error code that identifies why an error was thrown by the app middleware.\n */\nexport type ErrorCode =\n  | \"TOKEN_MISSING\"\n  | \"TOKEN_EXPIRED\"\n  | \"TOKEN_INVALID\"\n  | \"APP_ID_MISMATCH\";\n\n/**\n * @public\n * Base class for all user authentication errors.\n * All authentication errors extend this class.\n */\nexport class UserAuthError extends Error {\n  /** Machine-readable error code */\n  readonly code: ErrorCode;\n\n  /** HTTP status code to use when responding to the client */\n  readonly statusCode: number;\n\n  constructor(message: string, code: ErrorCode, statusCode: number) {\n    super(message);\n    this.code = code;\n    this.statusCode = statusCode;\n    Object.setPrototypeOf(this, UserAuthError.prototype);\n  }\n}\n\n/**\n * @public\n * Thrown when the JWT token is missing from the request.\n * This occurs when the token extractor cannot find a token in the expected location.\n */\nexport class TokenMissingError extends UserAuthError {\n  override readonly code = \"TOKEN_MISSING\";\n  override readonly statusCode = 401;\n\n  constructor(message: string) {\n    super(message, \"TOKEN_MISSING\", 401);\n    Object.setPrototypeOf(this, TokenMissingError.prototype);\n  }\n}\n\n/**\n * @public\n * Thrown when the JWT token has expired.\n * The token was valid but is no longer accepted due to expiration.\n */\nexport class TokenExpiredError extends UserAuthError {\n  override readonly code = \"TOKEN_EXPIRED\";\n  override readonly statusCode = 401;\n\n  /** When the token expired */\n  readonly expiredAt: Date;\n\n  constructor(message: string, expiredAt: Date) {\n    super(message, \"TOKEN_EXPIRED\", 401);\n    this.expiredAt = expiredAt;\n    Object.setPrototypeOf(this, TokenExpiredError.prototype);\n  }\n}\n\n/**\n * @public\n * Thrown when the JWT token signature is invalid or token is malformed.\n * This indicates the token has been tampered with or is not a valid JWT.\n */\nexport class TokenInvalidError extends UserAuthError {\n  override readonly code = \"TOKEN_INVALID\";\n  override readonly statusCode = 401;\n  /** Reason for the validation failure */\n  readonly reason?: string;\n\n  constructor(message: string, reason?: string) {\n    super(message, \"TOKEN_INVALID\", 401);\n    this.reason = reason;\n    Object.setPrototypeOf(this, TokenInvalidError.prototype);\n  }\n}\n\n/**\n * @public\n * Thrown when the app ID in the token doesn't match the expected app ID.\n * This prevents tokens issued for one app from being used with another.\n */\nexport class AppIdMismatchError extends UserAuthError {\n  override readonly code = \"APP_ID_MISMATCH\";\n  override readonly statusCode = 401;\n  /** The expected app ID */\n  readonly expectedAppId: string;\n\n  /** The app ID found in the token */\n  readonly actualAppId: string;\n\n  constructor(message: string, expectedAppId: string, actualAppId: string) {\n    super(message, \"APP_ID_MISMATCH\", 401);\n    this.expectedAppId = expectedAppId;\n    this.actualAppId = actualAppId;\n    Object.setPrototypeOf(this, AppIdMismatchError.prototype);\n  }\n}\n", "/**\n * Create a JWKS URL for a given app ID.\n * @param baseUrl - The base URL for the Canva API\n * @param appId - The Canva app ID\n * @returns The full JWKS URL\n */\nexport const createJwksUrl = (baseUrl: string, appId: string): string =>\n  `${baseUrl}/rest/v1/apps/${appId}/jwks`;\n\n/**\n * Check if a string looks like a valid JWT token.\n * @param token - The string to validate\n * @returns true if the string matches JWT format\n */\nexport const looksLikeJWT = (token: string): boolean =>\n  // Base64 alphabet includes\n  //   - letters (a-z and A-Z)\n  //   - digits (0-9)\n  //   - two special characters (+/ or -_)\n  //   - padding (=)\n  token.match(/^[a-z0-9+/\\-_=.]+$/i) != null;\n", "import type { Request } from \"express\";\nimport { debugLogger } from \"../../constants.js\";\nimport { looksLikeJWT } from \"../../core/utils.js\";\nimport { TokenInvalidError, TokenMissingError } from \"../../errors.js\";\nimport type { TokenExtractor } from \"./types.js\";\n\n/**\n * @public\n * Factory functions for extracting JWT tokens from various sources.\n * Use these with the `tokenExtractor` option in `user.verifyToken()`.\n */\nexport const tokenExtractors = {\n  /**\n   * Extracts a JWT token from the Authorization header using the Bearer scheme.\n   *\n   * @returns A token extractor function\n   */\n  fromBearerAuth(): TokenExtractor {\n    const headerName = \"Authorization\";\n    const scheme = \"Bearer\";\n    return (req: Request): string => {\n      const header = req.header(headerName);\n      if (!header) {\n        throw new TokenMissingError(`Missing the \"${headerName}\" header`);\n      }\n\n      const schemeRegex = new RegExp(`^${scheme}\\\\s+[^\\\\s]+$`, \"i\");\n      if (!header.match(schemeRegex)) {\n        debugLogger(\n          \"tokenExtractor: failed to match token in '%s' header\",\n          headerName,\n        );\n        throw new TokenMissingError(\n          `Missing a \"${scheme}\" token in the \"${headerName}\" header`,\n        );\n      }\n\n      const token = header.replace(new RegExp(`^${scheme}\\\\s+`, \"i\"), \"\");\n      if (!token || !looksLikeJWT(token)) {\n        throw new TokenInvalidError(\n          `Invalid \"${scheme}\" token in the \"${headerName}\" header`,\n          \"Token format is invalid\",\n        );\n      }\n\n      return token;\n    };\n  },\n\n  /**\n   * Extracts a JWT token from a query string parameter.\n   *\n   * @param paramName - The name of the query parameter\n   * @returns A token extractor function\n   */\n  fromQuery(paramName: string): TokenExtractor {\n    return (req: Request): string => {\n      const queryParam = req.query[paramName];\n      if (!queryParam || typeof queryParam !== \"string\") {\n        debugLogger(\"tokenExtractor: missing '%s' query parameter\", paramName);\n        throw new TokenMissingError(`Missing \"${paramName}\" query parameter`);\n      }\n\n      if (!looksLikeJWT(queryParam)) {\n        debugLogger(\"tokenExtractor: invalid '%s' query parameter\", paramName);\n        throw new TokenInvalidError(\n          `Invalid \"${paramName}\" query parameter`,\n          \"Token format is invalid\",\n        );\n      }\n\n      return queryParam;\n    };\n  },\n\n  /**\n   * Extracts a JWT token from a cookie.\n   * Requires cookie-parser middleware or similar to parse cookies.\n   *\n   * @param cookieName - The name of the cookie\n   * @returns A token extractor function\n   */\n  fromCookie(cookieName: string): TokenExtractor {\n    return (req: Request): string => {\n      const token = req.cookies?.[cookieName];\n      if (!token || typeof token !== \"string\") {\n        debugLogger(\"tokenExtractor: missing '%s' cookie\", cookieName);\n        throw new TokenMissingError(`Missing \"${cookieName}\" cookie`);\n      }\n\n      if (!looksLikeJWT(token)) {\n        debugLogger(\"tokenExtractor: invalid '%s' cookie\", cookieName);\n        throw new TokenInvalidError(\n          `Invalid \"${cookieName}\" cookie`,\n          \"Token format is invalid\",\n        );\n      }\n\n      return token;\n    };\n  },\n};\n", "import type { NextFunction, Request, RequestHandler, Response } from \"express\";\nimport { debugLogger } from \"../../constants.js\";\nimport { initUserTokenVerifier } from \"../../core/user.js\";\nimport { UserAuthError } from \"../../errors.js\";\nimport { tokenExtractors } from \"./extractors.js\";\nimport type { UserAuthOptions } from \"./types.js\";\n\n/**\n * Creates Express middleware for verifying Canva user JWT tokens obtained through https://www.canva.dev/docs/apps/api/latest/user-auth-get-canva-user-token/.\n *\n * @param options - Configuration options\n * @returns Express middleware\n */\nfunction createVerifyMiddleware({\n  appId,\n  tokenExtractor = tokenExtractors.fromBearerAuth(),\n  cacheMaxAgeMinutes,\n  timeoutMs,\n  baseUrl,\n}: UserAuthOptions): RequestHandler {\n  // Create verifier once when middleware is initialized\n  const verifier = initUserTokenVerifier({\n    appId,\n    cacheMaxAgeMinutes,\n    timeoutMs,\n    baseUrl,\n  });\n\n  return async (req: Request, _res: Response, next: NextFunction) => {\n    try {\n      debugLogger(\"Processing JWT for '%s'\", req.url);\n\n      // Extract token from request using the provided extractor\n      const token = await tokenExtractor(req);\n\n      // Use the verifier to verify the token\n      const payload = await verifier.verify(token);\n\n      // Attach user context to request in namespaced structure\n      req.canva = {\n        user: payload,\n      };\n\n      return next();\n    } catch (e) {\n      // Re-throw UserAuthError instances as-is (handled by error middleware)\n      if (e instanceof UserAuthError) {\n        return next(e);\n      }\n\n      // Unknown errors pass through\n      return next(e);\n    }\n  };\n}\n\n/**\n * @public\n * User token authentication namespace.\n * Provides middleware for verifying Canva user JWT tokens.\n */\nexport const user = {\n  /**\n   * Creates Express middleware for verifying Canva user JWT tokens.\n   * When verification succeeds, adds user context to `req.canva.user`.\n   *\n   * @param options - Configuration options\n   * @returns Express middleware that verifies JWT tokens\n   *\n   * @example\n   * Basic usage with default Authorization header:\n   * ```typescript\n   * import { user } from '@canva/app-middleware/express';\n   *\n   * app.use(user.verifyToken({ appId: 'your-app-id' }));\n   * ```\n   *\n   * @example\n   * With custom token extraction:\n   * ```typescript\n   * import { user, tokenExtractors } from '@canva/app-middleware/express';\n   *\n   * app.use(user.verifyToken({\n   *   appId: 'your-app-id',\n   *   tokenExtractor: tokenExtractors.fromQuery('token')\n   * }));\n   * ```\n   */\n  verifyToken: createVerifyMiddleware,\n};\n"],
