/**
 * @public
 * The verified payload from a Canva user JWT token.
 */
export type UserTokenPayload = {
  /** The ID of the Canva app */
  appId: string;
  /** The ID of the authenticated user */
  userId: string;
  /** The ID of the user's team/brand */
  brandId: string;
};
/**
 * @public
 * Configuration options for initializing a user token verifier.
 */
export type UserTokenVerifierOptions = {
  /**
   * The ID of the Canva app, obtained via the developer portal canva.com/developers.
   */
  appId: string;
  /**
   * The maximum age of the JWKS cache in minutes.
   * @defaultValue 60
   */
  cacheMaxAgeMinutes?: number;
  /**
   * The timeout for the JWKS fetch in milliseconds.
   * @defaultValue 30000
   */
  timeoutMs?: number;
  /**
   * The base URL for the JWKS endpoint.
   * @defaultValue "https://api.canva.com"
   */
  baseUrl?: string;
};
/**
 * @public
 * A configured verifier for Canva user JWT tokens.
 */
export type UserTokenVerifier = {
  /**
   * Verifies a Canva user JWT token and returns the decoded payload.
   *
   * @param token - The JWT token to verify
   * @returns The verified user token payload
   * @throws {TokenInvalidError} When the token is malformed or has an invalid signature
   * @throws {TokenExpiredError} When the token has expired
   */
  verify(token: string): Promise<UserTokenPayload>;
};
