import type { Request } from "express";
import type {
  UserTokenPayload,
  UserTokenVerifierOptions,
} from "../../core/types.js";
/**
 * Augment the Express request context to include user authentication context
 * in a namespaced structure.
 */
declare module "express-serve-static-core" {
  interface Request {
    canva: {
      /** User authentication context from verified JWT */
      user?: UserTokenPayload;
    };
  }
}
/**
 * @public
 * A function that extracts a JWT token from the request.
 */
export type TokenExtractor = (req: Request) => Promise<string> | string;
/**
 * @public
 * Configuration options for user authentication middleware.
 */
export type UserAuthOptions = UserTokenVerifierOptions & {
  /**
   * A function that extracts a JWT token from the request.
   * @defaultValue tokenExtractors.fromBearerAuth()
   */
  tokenExtractor?: TokenExtractor;
};
