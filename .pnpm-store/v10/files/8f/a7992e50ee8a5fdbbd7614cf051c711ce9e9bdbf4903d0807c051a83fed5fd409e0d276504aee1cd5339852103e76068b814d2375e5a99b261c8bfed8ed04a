export class FakeMonetizationClient {
    async isEnabled(action) {
        await this.delay();
        return true;
    }
    async openTrackingSession(opts) {
        await this.delay();
        return {
            id: 'id',
            closeTrackingSession: async ()=>{}
        };
    }
    async requestEnableBillableAction(action) {
        await this.delay();
        return {
            status: 'granted'
        };
    }
    constructor(delay){
        this.delay = delay;
    }
}
