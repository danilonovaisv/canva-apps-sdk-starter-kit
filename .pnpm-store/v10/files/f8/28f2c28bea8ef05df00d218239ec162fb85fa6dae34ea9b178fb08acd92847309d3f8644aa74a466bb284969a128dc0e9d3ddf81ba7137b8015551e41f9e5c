  "description": "Utilities and Express.js middleware for Apps SDK server-side functionality.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "files": [
    "src",
    "lib",
    "LICENSE.md",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "canva",
    "apps-sdk",
    "express",
    "jwt",
    "middleware",
    "authentication"
  ],
  "main": "./lib/cjs/index.cjs",
