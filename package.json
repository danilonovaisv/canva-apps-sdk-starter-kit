{
  "name": "canva-apps-sdk-starter-kit",
  "description": "A boilerplate for creating Canva Apps.",
  "engines": {
    "node": "^22 || ^24"
  },
  "scripts": {
    "start": "tsx ./scripts/start/start.ts",
    "start:preview": "npm run start -- --preview",
    "extract": "formatjs extract \"src/**/*.{ts,tsx}\" --ignore \"src/**/*.d.ts\" --out-file dist/messages_en.json",
    "build": "webpack --config webpack.config.ts --mode production && npm run extract",
    "build:production": "npm run env:production && npm run build",
    "env:local": "bash ./scripts/use-local-env.sh",
    "env:production": "bash ./scripts/use-production-env.sh",
    "deploy:firebase": "bash ./scripts/deploy-firebase.sh",
    "deploy:frontend": "bash -c 'trap \"npm run env:local\" EXIT; npm run build:production && firebase deploy --only hosting:frontend --project canva-app-5f36c'",
    "deploy:api": "firebase deploy --only functions,hosting:api --project canva-app-5f36c",
    "deploy:hosting": "firebase deploy --only hosting --project canva-app-5f36c",
    "deploy:functions": "firebase deploy --only functions --project canva-app-5f36c",
    "lint:types": "tsc",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier '{examples,src,utils,scripts}/**/*.{css,ts,tsx,json,js,mjs}' --write",
    "format:check": "prettier '{examples,src,utils,scripts}/**/*.{css,ts,tsx,json,js,mjs}' --check",
    "format:file": "prettier $1 --no-config --write",
    "test": "jest --no-cache --detectOpenHandles",
    "test:watch": "jest --no-cache --watch",
    "postinstall": "tsx ./scripts/copy_env.ts"
  },
  "keywords": [],
  "author": "Canva Pty Ltd.",
  "license": "SEE LICENSE IN LICENSE.md",
  "private": true,
  "workspaces": [
    "./examples/*/*"
  ],
  "dependencies": {
    "@canva/app-hooks": "^0.0.0-beta.4",
    "@canva/app-i18n-kit": "^1.2.0",
    "@canva/app-middleware": "^0.0.0-beta.1",
    "@canva/app-ui-kit": "^5.10.0",
    "@canva/asset": "^2.3.0",
    "@canva/design": "^2.9.0",
    "@canva/error": "^2.2.1",
    "@canva/intents": "^2.6.0",
    "@canva/platform": "^2.2.2",
    "@canva/user": "^2.2.0",
    "mobx": "^6.16.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-intl": "^6.6.8"
  },
  "devDependencies": {
    "@canva/app-eslint-plugin": "^1.0.0-beta.7",
    "@canva/cli": "^2.3.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@formatjs/cli": "6.16.11",
    "@formatjs/ts-transformer": "^4.4.13",
    "@ngrok/ngrok": "1.7.0",
    "@svgr/webpack": "8.1.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/debug": "4.1.13",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.9.3",
    "@types/node-fetch": "2.6.13",
    "@types/node-forge": "1.3.14",
    "@types/nodemon": "3.1.1",
    "@types/prompts": "2.4.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/webpack-env": "1.18.8",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "css-loader": "7.1.4",
    "css-modules-typescript-loader": "4.0.1",
    "cssnano": "8.0.2",
    "debug": "4.4.3",
    "dotenv": "17.4.2",
    "esbuild-register": "3.6.0",
    "eslint": "^9.20.0",
    "eslint-plugin-formatjs": "^6.4.15",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "exponential-backoff": "3.1.3",
    "express": "5.2.1",
    "express-basic-auth": "1.2.1",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "jest-css-modules-transform": "4.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jsonwebtoken": "9.0.3",
    "jwks-rsa": "4.0.1",
    "mini-css-extract-plugin": "2.10.2",
    "node-fetch": "3.3.2",
    "node-forge": "1.4.0",
    "nodemon": "3.1.14",
    "open": "11.0.0",
    "postcss-loader": "8.2.1",
    "prettier": "3.8.4",
    "prompts": "2.4.2",
    "style-loader": "4.0.0",
    "terser-webpack-plugin": "5.6.1",
    "tree-kill": "1.2.2",
    "ts-jest": "29.4.11",
    "ts-loader": "9.6.0",
    "tslib": "^2.8.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "url-loader": "4.1.1",
    "webpack": "5.107.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.5",
    "yargs": "18.0.0"
  },
  "overrides": {
    "react-infinite-scroller": {
      "react": "$react"
    }
  }
}
